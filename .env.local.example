# DM-Instamap local override template.
# Copy to .env.local when you want machine-specific settings.

DM_INSTAMAP_ALLOW_REMOTE=false
# When remote access is enabled, optionally restrict and throttle LAN clients.
# Comma-separated client IPs allowed in addition to localhost (empty = no extra
# restriction). The client IP is read from the x-forwarded-for header.
DM_INSTAMAP_ALLOWED_IPS=
# Max requests per client IP per minute (0 or unset = disabled).
DM_INSTAMAP_RATE_LIMIT_PER_MINUTE=0
DM_INSTAMAP_WORKER_URL=http://127.0.0.1:8000
DM_INSTAMAP_JOBS_DB=
DM_INSTAMAP_WORKER_CONCURRENCY=2
DM_INSTAMAP_JOBS_RETENTION_DAYS=30
DM_INSTAMAP_JOBS_MAX_TERMINAL=500

# Optional AI. Leave unset for local-only/manual bridge mode.
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=
AI_BASE_URL=
AI_MAX_TOKENS=

# Offline mock for demos/tests that must not call a real provider.
# AI_PROVIDER=mock
