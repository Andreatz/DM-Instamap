# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
.next/
out/
coverage/
playwright-report/
test-results/
.turbo/
*.tsbuildinfo

# Heavy local asset sources
data/indexes/
data/previews/
data/raw-assets/
local-assets/
assets-local/
local-references/
reference-maps-local/
*.dungeondraft_pack

# Asset taxonomy pipeline — large generated/input artifacts.
# Regenerate with `pnpm assets:import-tags && assets:map-taxonomy && assets:manifest`.
# Small, hand-maintained files (overrides, reports, asset-taxonomy.json and the
# v3 taxonomy seed) stay tracked via the negations below.
data/assets/imports/*.json
data/assets/manifests/*.json
data/assets/asset-manifest.json
data/assets/contact-sheets/
!data/assets/taxonomy/dm_instamap_taxonomy_merged_v3.json

# Local generated project/export output
data/projects/
data/exports/

# Local data backups (pnpm data:backup default destination)
backups/

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.venv/
venv/

# Local environment
.env
.env.*
!.env.example
!.env.local.example
*.log

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Claude Code local (machine-specific) settings
.claude/settings.local.json
