{
  "name": "@dm-instamap/assets",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./embeddings": {
      "import": "./src/embeddings.ts",
      "types": "./src/embeddings.ts"
    },
    "./image-generation": {
      "import": "./src/image-generation.ts",
      "types": "./src/image-generation.ts"
    },
    "./pack-importer": {
      "import": "./src/pack-importer.ts",
      "types": "./src/pack-importer.ts"
    },
    "./scanner": {
      "import": "./src/scanner.ts",
      "types": "./src/scanner.ts"
    },
    "./matcher": {
      "import": "./src/matcher.ts",
      "types": "./src/matcher.ts"
    }
  },
  "scripts": {
    "analyze-image": "tsx src/cli/analyze-image.ts",
    "audit": "tsx src/cli/audit.ts",
    "build": "tsc -p tsconfig.build.json",
    "embed": "tsx src/cli/embed.ts",
    "generate": "tsx src/cli/generate.ts",
    "group": "tsx src/cli/group.ts",
    "import-pack": "tsx src/cli/import-pack.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "references:scan": "tsx src/cli/references-scan.ts",
    "references:style": "tsx src/cli/references-style.ts",
    "scan": "tsx src/cli/scan.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@dm-instamap/core": "workspace:*",
    "sharp": "^0.34.5"
