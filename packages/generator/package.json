{
  "name": "@dm-instamap/generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "benchmark": "tsx src/cli/benchmark.ts",
    "build": "tsc -p tsconfig.build.json",
