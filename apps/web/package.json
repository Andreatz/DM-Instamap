{
  "name": "@dm-instamap/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "campaigns:create": "tsx src/lib/cli/campaigns.ts create",
    "campaigns:list": "tsx src/lib/cli/campaigns.ts list",
    "data:backup": "tsx src/lib/cli/data.ts backup",
    "data:restore": "tsx src/lib/cli/data.ts restore",
    "dev": "next dev --hostname 127.0.0.1",
    "snapshots:create": "tsx src/lib/cli/snapshots.ts create",
    "snapshots:list": "tsx src/lib/cli/snapshots.ts list",
    "snapshots:restore": "tsx src/lib/cli/snapshots.ts restore",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@dm-instamap/assets": "workspace:*",
    "@dm-instamap/ai-bridge": "workspace:*",
    "@dm-instamap/core": "workspace:*",
    "@dm-instamap/exporters": "workspace:*",
    "@dm-instamap/generator": "workspace:*",
    "next": "^16.0.10",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  }
}
