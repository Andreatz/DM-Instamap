{
  "name": "dm-instamap",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first modular map generator for D&D.",
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "assets:analyze-image": "pnpm --filter @dm-instamap/assets analyze-image",
    "assets:generate": "pnpm --filter @dm-instamap/assets generate",
    "assets:group": "pnpm --filter @dm-instamap/assets group",
    "assets:import-pack": "pnpm --filter @dm-instamap/assets import-pack",
    "assets:audit": "pnpm --filter @dm-instamap/assets run audit",
    "assets:embed": "pnpm --filter @dm-instamap/assets embed",
    "assets:scan": "pnpm --filter @dm-instamap/assets scan",
    "ai:blueprint": "pnpm --filter @dm-instamap/ai-bridge blueprint",
    "ai:plan": "pnpm --filter @dm-instamap/ai-bridge plan",
    "build": "pnpm -r --if-present build",
    "campaigns:create": "pnpm --filter @dm-instamap/web campaigns:create",
    "campaigns:list": "pnpm --filter @dm-instamap/web campaigns:list",
    "dev": "pnpm --filter @dm-instamap/web dev",
    "exports:session-pack": "pnpm --filter @dm-instamap/exporters session-pack",
    "lint": "pnpm -r --if-present lint",
    "references:scan": "pnpm --filter @dm-instamap/assets references:scan",
    "references:style": "pnpm --filter @dm-instamap/assets run references:style",
    "repo:audit": "node scripts/audit-versioned-assets.mjs",
    "snapshots:create": "pnpm --filter @dm-instamap/web snapshots:create",
    "snapshots:list": "pnpm --filter @dm-instamap/web snapshots:list",
    "snapshots:restore": "pnpm --filter @dm-instamap/web snapshots:restore",
    "test": "pnpm -r --if-present test",
    "test:e2e": "playwright test",
    "worker:dev": "pnpm --filter @dm-instamap/worker dev",
    "worker:install": "python -m pip install -r apps/worker/requirements-dev.txt"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
